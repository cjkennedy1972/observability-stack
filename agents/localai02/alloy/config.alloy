// ── Alloy config for localai02 ────────────────────────────────────────────────
// Ships Docker container logs to central Loki with structured parsing.
// LocalAI logs: ANSI-stripped, logfmt key=value fields extracted.
// LOKI_URL is injected via docker-compose environment.

// ── Docker discovery ─────────────────────────────────────────────────────────
discovery.docker "containers" {
  host = "unix:///var/run/docker.sock"
}

discovery.relabel "docker_meta" {
  targets = discovery.docker.containers.targets

  rule {
    source_labels = ["__meta_docker_container_name"]
    regex         = "/(.*)"
    target_label  = "container"
  }

  rule {
    source_labels = ["__meta_docker_container_label_com_docker_compose_service"]
    target_label  = "service"
  }

  rule {
    target_label = "host"
    replacement  = "localai02"
  }

  rule {
    target_label = "job"
    replacement  = "docker/localai02"
  }
}

// ── Collect Docker logs ───────────────────────────────────────────────────────
loki.source.docker "docker_logs" {
  host       = "unix:///var/run/docker.sock"
  targets    = discovery.relabel.docker_meta.output
  forward_to = [loki.process.parse_logs.receiver]
}

// ── Processing pipeline ───────────────────────────────────────────────────────
loki.process "parse_logs" {
  forward_to = [loki.write.central.receiver]

  // 1. Strip ANSI color/control codes
  stage.replace {
    expression = "\\x1b\\[[0-9;]*[mGKHF]"
    replace    = ""
  }

  // 2. Extract log level
  stage.regex {
    expression = `(?i)^\S+\s+(?P<level>INFO|WARN|ERROR|DEBUG|TRACE|FATAL)\s+`
  }

  stage.labels {
    values = {
      level = "",
    }
  }

  // 3. Extract HTTP request fields into structured metadata
  stage.logfmt {
    mapping = {
      "http_method" = "method",
      "http_path"   = "path",
      "http_status" = "status",
    }
  }

  stage.structured_metadata {
    values = {
      method = "",
      path   = "",
      status = "",
    }
  }
}

// ── Write to Loki ─────────────────────────────────────────────────────────────
loki.write "central" {
  endpoint {
    url = env("LOKI_URL")
  }
}
