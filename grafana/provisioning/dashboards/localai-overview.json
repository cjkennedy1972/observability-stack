{
  "title": "LocalAI — Overview",
  "uid": "localai-overview",
  "tags": ["localai", "inference"],
  "timezone": "browser",
  "refresh": "30s",
  "schemaVersion": 38,
  "panels": [
    {
      "id": 1,
      "title": "LocalAI Instances Up",
      "type": "stat",
      "gridPos": {"h": 4, "w": 6, "x": 0, "y": 0},
      "targets": [
        {
          "datasource": {"uid": "prometheus"},
          "expr": "sum(up{job=~\"localai.*\", job!~\"node.*|gpu.*\"})",
          "legendFormat": "Up"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {"steps": [{"color": "red", "value": 0}, {"color": "green", "value": 2}]},
          "mappings": []
        }
      }
    },
    {
      "id": 2,
      "title": "API Request Rate (req/s)",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 4},
      "targets": [
        {
          "datasource": {"uid": "prometheus"},
          "expr": "sum by (host) (rate(api_call_count{job=~\"localai.*\", path!=\"\"}[5m]))",
          "legendFormat": "{{ host }}"
        }
      ]
    },
    {
      "id": 3,
      "title": "API p95 Latency (ms)",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 4},
      "targets": [
        {
          "datasource": {"uid": "prometheus"},
          "expr": "histogram_quantile(0.95, sum by (host, le) (rate(api_call_bucket{job=~\"localai.*\"}[5m])))",
          "legendFormat": "p95 {{ host }}"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "ms"}}
    },
    {
      "id": 4,
      "title": "localai01 — NVIDIA GPU VRAM Used %",
      "type": "gauge",
      "gridPos": {"h": 4, "w": 6, "x": 0, "y": 12},
      "targets": [
        {
          "datasource": {"uid": "prometheus"},
          "expr": "(amd_smi_vram_used_bytes{host=\"localai01\"} / amd_smi_vram_total_bytes{host=\"localai01\"}) * 100",
          "legendFormat": "GPU {{ gpu_id }}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {"steps": [{"color": "green", "value": 0}, {"color": "yellow", "value": 70}, {"color": "red", "value": 90}]}
        }
      }
    },
    {
      "id": 5,
      "title": "localai02 — NVIDIA GPU VRAM Used %",
      "type": "gauge",
      "gridPos": {"h": 4, "w": 6, "x": 6, "y": 12},
      "targets": [
        {
          "datasource": {"uid": "prometheus"},
          "expr": "(nvidia_smi_memory_used_bytes{host=\"localai02\"} / nvidia_smi_memory_total_bytes{host=\"localai02\"}) * 100",
          "legendFormat": "RTX 5070 Ti"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {"steps": [{"color": "green", "value": 0}, {"color": "yellow", "value": 70}, {"color": "red", "value": 90}]}
        }
      }
    },
    {
      "id": 6,
      "title": "GPU Temperature",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 16},
      "targets": [
        {
          "datasource": {"uid": "prometheus"},
          "expr": "amd_smi_temperature_celsius{host=\"localai01\"}",
          "legendFormat": "localai01 GPU {{ gpu_id }}"
        },
        {
          "datasource": {"uid": "prometheus"},
          "expr": "nvidia_smi_temperature_gpu{host=\"localai02\"}",
          "legendFormat": "localai02 RTX5070Ti"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "celsius"}}
    },
    {
      "id": 7,
      "title": "GPU Utilization %",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 16},
      "targets": [
        {
          "datasource": {"uid": "prometheus"},
          "expr": "amd_smi_gpu_busy_percent{host=\"localai01\"}",
          "legendFormat": "localai01 GPU {{ gpu_id }}"
        },
        {
          "datasource": {"uid": "prometheus"},
          "expr": "nvidia_smi_utilization_gpu_ratio{host=\"localai02\"} * 100",
          "legendFormat": "localai02 RTX5070Ti"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "percent"}}
    }
  ]
}
