    {
      "id": 23,
      "title": "Inferences/Hour — By Host",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 25},
      "description": "Number of inference requests processed per hour",
      "targets": [
        {
          "datasource": {"uid": "tempo"},
          "queryType": "traceql",
          "query": "{ resource.service.name=\"localai-localai01\" } | count()",
          "legendFormat": "AMD (localai01)"
        },
        {
          "datasource": {"uid": "tempo"},
          "queryType": "traceql",
          "query": "{ resource.service.name=\"localai-localai02\" } | count()",
          "legendFormat": "NVIDIA (localai02)"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {"lineWidth": 2, "fillOpacity": 10},
          "color": {"mode": "palette-classic"}
        }
      },
      "options": {
        "legend": {"showLegend": true, "placement": "bottom", "calcs": ["sum", "last"]},
        "tooltip": {"mode": "multi"}
      }
    },

    {
      "id": 24,
      "title": "Prompt vs Completion Token Ratio",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 25},
