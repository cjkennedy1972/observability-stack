    {
      "id": 20,
      "title": "Tokens/Second Over Time — By Host",
      "type": "timeseries",
      "gridPos": {"h": 9, "w": 24, "x": 0, "y": 8},
      "description": "Real-time token generation rate (completion tokens per second)",
      "targets": [
        {
          "datasource": {"uid": "tempo"},
          "queryType": "traceql",
          "query": "{ resource.service.name=\"localai-localai01\" } | avg(span.localai.tokens_per_second)",
          "legendFormat": "AMD (localai01)"
        },
        {
          "datasource": {"uid": "tempo"},
          "queryType": "traceql",
          "query": "{ resource.service.name=\"localai-localai02\" } | avg(span.localai.tokens_per_second)",
          "legendFormat": "NVIDIA (localai02)"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {"lineWidth": 3, "fillOpacity": 20},
          "color": {"mode": "palette-classic"}
        }
      },
      "options": {
        "legend": {"showLegend": true, "placement": "bottom", "calcs": ["mean", "max", "last"]},
        "tooltip": {"mode": "multi"}
      }
    },

    {
      "id": 21,
      "title": "Prompt Tokens/Request — By Host",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 17},
