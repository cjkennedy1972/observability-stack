{
  "title": "LocalAI — Token Throughput & Processing",
  "uid": "localai-tokens",
  "tags": ["localai", "tokens", "throughput", "performance"],
  "timezone": "browser",
  "refresh": "30s",
  "schemaVersion": 38,
  "time": {"from": "now-24h", "to": "now"},
  "templating": {"list": []},
  "panels": [
    {
      "id": 1,
      "title": "Total Inferences Processed",
      "type": "stat",
      "gridPos": {"h": 4, "w": 8, "x": 0, "y": 0},
      "targets": [
        {
          "datasource": {"uid": "tempo"},
          "queryType": "traceql",
          "query": "{ resource.service.name=~\"localai-.*\" }",
          "legendFormat": "Total"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {"mode": "palette-classic"}
        }
      },
      "options": {"textMode": "auto", "colorMode": "value", "graphMode": "none", "orientation": "vertical", "reduceOptions": {"calcs": ["count"]}}
    },

    {
      "id": 2,
      "title": "AMD (localai01) Inference Count",
      "type": "stat",
      "gridPos": {"h": 4, "w": 8, "x": 8, "y": 0},
      "targets": [
        {
          "datasource": {"uid": "tempo"},
          "queryType": "traceql",
          "query": "{ resource.service.name=\"localai-localai01\" }",
          "legendFormat": "AMD"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {"mode": "palette-classic"}
        }
      },
      "options": {"textMode": "auto", "colorMode": "value", "graphMode": "none", "orientation": "vertical", "reduceOptions": {"calcs": ["count"]}}
    },

    {
      "id": 3,
      "title": "NVIDIA (localai02) Inference Count",
      "type": "stat",
      "gridPos": {"h": 4, "w": 8, "x": 16, "y": 0},
      "targets": [
        {
          "datasource": {"uid": "tempo"},
          "queryType": "traceql",
          "query": "{ resource.service.name=\"localai-localai02\" }",
          "legendFormat": "NVIDIA"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {"mode": "palette-classic"}
        }
      },
      "options": {"textMode": "auto", "colorMode": "value", "graphMode": "none", "orientation": "vertical", "reduceOptions": {"calcs": ["count"]}}
    },

    {
      "id": 10,
      "title": "Recent Inferences — Detailed Metrics",
      "type": "traces",
      "gridPos": {"h": 10, "w": 24, "x": 0, "y": 4},
      "description": "Click any trace to inspect full token metrics (prompt, completion, efficiency)",
      "datasource": {"uid": "tempo"},
      "targets": [
        {
          "datasource": {"uid": "tempo"},
          "queryType": "traceql",
          "query": "{ resource.service.name=~\"localai-.*\" } | select(span.localai.model, span.localai.backend, span.localai.tokens.prompt, span.localai.tokens.completion, span.localai.tokens.total, span.localai.tokens_per_second, span.localai.duration_ms) | sort(startTime desc)"
        }
      ],
      "options": {"showSpanFilterButton": true}
    },

    {
      "id": 20,
      "title": "Average Tokens/Request — Prompt",
      "type": "stat",
      "gridPos": {"h": 6, "w": 8, "x": 0, "y": 14},
      "description": "Average input tokens per inference request",
      "targets": [
        {
          "datasource": {"uid": "tempo"},
          "queryType": "traceql",
          "query": "{ resource.service.name=~\"localai-.*\" } | select(span.localai.tokens.prompt)"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {"mode": "palette-classic"}
        }
      },
      "options": {"textMode": "auto", "colorMode": "value", "graphMode": "none", "orientation": "vertical", "reduceOptions": {"calcs": ["mean"]}}
    },

    {
      "id": 21,
      "title": "Average Tokens/Request — Completion",
      "type": "stat",
      "gridPos": {"h": 6, "w": 8, "x": 8, "y": 14},
      "description": "Average output tokens per inference request",
      "targets": [
        {
          "datasource": {"uid": "tempo"},
          "queryType": "traceql",
          "query": "{ resource.service.name=~\"localai-.*\" } | select(span.localai.tokens.completion)"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {"mode": "palette-classic"}
        }
      },
      "options": {"textMode": "auto", "colorMode": "value", "graphMode": "none", "orientation": "vertical", "reduceOptions": {"calcs": ["mean"]}}
    },

    {
      "id": 22,
      "title": "Max Tokens/Second Throughput",
      "type": "stat",
      "gridPos": {"h": 6, "w": 8, "x": 16, "y": 14},
      "description": "Peak token generation rate observed",
      "targets": [
        {
          "datasource": {"uid": "tempo"},
          "queryType": "traceql",
          "query": "{ resource.service.name=~\"localai-.*\" } | select(span.localai.tokens_per_second)"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {"mode": "palette-classic"}
        }
      },
      "options": {"textMode": "auto", "colorMode": "value", "graphMode": "none", "orientation": "vertical", "reduceOptions": {"calcs": ["max"]}}
    },

    {
      "id": 30,
      "title": "Models Used",
      "type": "table",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 20},
      "description": "Inference count by model",
      "targets": [
        {
          "datasource": {"uid": "tempo"},
          "queryType": "traceql",
          "query": "{ resource.service.name=~\"localai-.*\" } | select(span.localai.model)"
        }
      ]
    },

    {
      "id": 31,
      "title": "Inference Duration Distribution",
      "type": "histogram",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 20},
      "description": "How long inference requests take (end-to-end)",
      "targets": [
        {
          "datasource": {"uid": "tempo"},
          "queryType": "traceql",
          "query": "{ resource.service.name=~\"localai-.*\" } | select(span.localai.duration_ms)"
        }
      ]
    }
  ]
}
