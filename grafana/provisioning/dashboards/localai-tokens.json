    {
      "id": 40,
      "title": "Inference Duration (ms) — By Host",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 41},
      "description": "Average time to complete inference request (end-to-end latency)",
      "targets": [
        {
          "datasource": {"uid": "tempo"},
          "queryType": "traceql",
          "query": "{ resource.service.name=\"localai-localai01\" } | avg(span.localai.duration_ms)",
