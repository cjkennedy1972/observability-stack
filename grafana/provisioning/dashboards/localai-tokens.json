{
  "title": "LocalAI — Token Throughput & Processing",
  "uid": "localai-tokens",
  "tags": ["localai", "tokens", "throughput", "performance"],
  "timezone": "browser",
  "refresh": "5s",
  "schemaVersion": 38,
  "time": {"from": "now-1h", "to": "now"},
  "templating": {"list": []},
  "panels": [
    {
      "id": 1,
      "title": "Tokens/Second (Total) — Live",
      "type": "stat",
      "gridPos": {"h": 4, "w": 8, "x": 0, "y": 0},
      "targets": [
        {
          "datasource": {"uid": "tempo"},
          "queryType": "traceql",
          "query": "{ resource.service.name=~\"localai-.*\" } | avg(span.localai.tokens_per_second)",
          "legendFormat": "Avg tok/s (all)"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {"mode": "palette-classic"},
          "custom": {"hideFrom": {"tooltip": false, "viz": false, "legend": false}}
        }
      },
      "options": {"textMode": "auto", "colorMode": "value", "graphMode": "area", "orientation": "vertical", "reduceOptions": {"calcs": ["lastNotNull"]}}
    },

    {
      "id": 2,
      "title": "Tokens/Second — AMD (localai01)",
      "type": "stat",
      "gridPos": {"h": 4, "w": 8, "x": 8, "y": 0},
      "targets": [
        {
          "datasource": {"uid": "tempo"},
          "queryType": "traceql",
          "query": "{ resource.service.name=\"localai-localai01\" } | avg(span.localai.tokens_per_second)",
          "legendFormat": "AMD tok/s"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {"mode": "palette-classic"}
        }
      },
      "options": {"textMode": "auto", "colorMode": "value", "graphMode": "area", "orientation": "vertical", "reduceOptions": {"calcs": ["lastNotNull"]}}
    },

    {
      "id": 3,
