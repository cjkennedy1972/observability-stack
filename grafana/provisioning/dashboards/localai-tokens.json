      "targets": [
        {
          "datasource": {"uid": "tempo"},
          "queryType": "traceql",
          "query": "{ resource.service.name=\"localai-localai01\" } | sum(span.localai.tokens.prompt) / sum(span.localai.tokens.completion)",
          "legendFormat": "AMD Ratio"
        },
        {
          "datasource": {"uid": "tempo"},
          "queryType": "traceql",
          "query": "{ resource.service.name=\"localai-localai02\" } | sum(span.localai.tokens.prompt) / sum(span.localai.tokens.completion)",
          "legendFormat": "NVIDIA Ratio"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {"lineWidth": 2, "fillOpacity": 0},
          "color": {"mode": "palette-classic"}
        }
      },
      "options": {
        "legend": {"showLegend": true, "placement": "bottom", "calcs": ["last"]},
        "tooltip": {"mode": "multi"}
      }
    },

