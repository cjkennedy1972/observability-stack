      "targets": [
        {
          "datasource": {"uid": "tempo"},
          "queryType": "traceql",
          "query": "{ resource.service.name=\"localai-localai01\" } | max(span.localai.tokens_per_second)",
          "legendFormat": "AMD Peak (localai01)"
