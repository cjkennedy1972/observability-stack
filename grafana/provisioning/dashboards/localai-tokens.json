    {
      "id": 12,
      "title": "Total Tokens Processed",
      "type": "stat",
      "gridPos": {"h": 4, "w": 8, "x": 16, "y": 4},
      "targets": [
        {
          "datasource": {"uid": "tempo"},
          "queryType": "traceql",
          "query": "{ resource.service.name=~\"localai-.*\" } | sum(span.localai.tokens.total)",
          "legendFormat": "Total tokens"
        }
