{
  "title": "Openclaw — Gateway Overview",
  "uid": "openclaw-overview",
  "tags": ["openclaw", "gateway"],
  "timezone": "browser",
  "refresh": "30s",
  "schemaVersion": 38,
  "panels": [
    {
      "id": 1,
      "title": "Token Usage Rate (tokens/min)",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
      "targets": [
        {
          "datasource": {"uid": "prometheus"},
          "expr": "rate(openclaw_tokens_total{type=\"input\"}[5m]) * 60",
          "legendFormat": "Input Tokens"
        },
        {
          "datasource": {"uid": "prometheus"},
          "expr": "rate(openclaw_tokens_total{type=\"output\"}[5m]) * 60",
          "legendFormat": "Output Tokens"
        },
        {
          "datasource": {"uid": "prometheus"},
          "expr": "rate(openclaw_tokens_total{type=\"cache_read\"}[5m]) * 60",
          "legendFormat": "Cache Read"
        }
      ]
    },
    {
      "id": 2,
      "title": "Estimated Cost (USD/hr)",
      "type": "stat",
      "gridPos": {"h": 4, "w": 6, "x": 12, "y": 0},
      "targets": [
        {
          "datasource": {"uid": "prometheus"},
          "expr": "rate(openclaw_cost_usd_total[1h]) * 3600",
          "legendFormat": "$/hr"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "decimals": 4,
          "thresholds": {"steps": [{"color": "green", "value": 0}, {"color": "yellow", "value": 0.5}, {"color": "red", "value": 1.0}]}
        }
      }
    },
    {
      "id": 3,
      "title": "Agent Turn Duration p50/p95 (ms)",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8},
      "targets": [
        {
          "datasource": {"uid": "prometheus"},
          "expr": "histogram_quantile(0.50, rate(openclaw_run_duration_ms_bucket[5m]))",
          "legendFormat": "p50"
        },
        {
          "datasource": {"uid": "prometheus"},
          "expr": "histogram_quantile(0.95, rate(openclaw_run_duration_ms_bucket[5m]))",
          "legendFormat": "p95"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "ms"}}
    },
    {
      "id": 4,
      "title": "Context Size (tokens)",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8},
      "targets": [
        {
          "datasource": {"uid": "prometheus"},
          "expr": "openclaw_context_tokens",
          "legendFormat": "Context Tokens"
        }
      ]
    },
    {
      "id": 5,
      "title": "Openclaw Host — CPU & Memory",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 16},
      "targets": [
        {
          "datasource": {"uid": "prometheus"},
          "expr": "100 - (avg by(instance)(rate(node_cpu_seconds_total{mode=\"idle\",job=\"node_openclaw\"}[5m])) * 100)",
          "legendFormat": "CPU %"
        },
        {
          "datasource": {"uid": "prometheus"},
          "expr": "(1 - (node_memory_MemAvailable_bytes{job=\"node_openclaw\"} / node_memory_MemTotal_bytes{job=\"node_openclaw\"})) * 100",
          "legendFormat": "Memory %"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "percent"}}
    },
    {
      "id": 6,
      "title": "Traces — Recent Spans",
      "type": "traces",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 16},
      "datasource": {"uid": "tempo"},
      "targets": [
        {
          "datasource": {"uid": "tempo"},
          "queryType": "traceql",
          "query": "{resource.service.name=\"openclaw-gateway\"} | select(span:duration) | sort(duration desc) | limit 20"
        }
      ]
    }
  ]
}
