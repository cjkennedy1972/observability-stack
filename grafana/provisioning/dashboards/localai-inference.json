{
  "title": "LocalAI GPU Inference — Operations Dashboard",
  "uid": "localai-inference",
  "tags": ["localai", "gpu", "inference", "operations"],
  "timezone": "browser",
  "refresh": "5s",
  "schemaVersion": 38,
  "time": {"from": "now-1h", "to": "now"},
  "templating": {"list": []},
  "panels": [
    {
      "id": 100,
      "title": "System Status",
      "type": "stat",
      "gridPos": {"h": 4, "w": 4, "x": 0, "y": 0},
      "targets": [
        {"datasource": {"uid": "prometheus"}, "expr": "amd_smi_up{instance=\"172.31.25.75:2021\"}", "legendFormat": "AMD (localai01)"},
        {"datasource": {"uid": "prometheus"}, "expr": "nvidia_smi_up{instance=\"10.25.25.67:9835\"}", "legendFormat": "NVIDIA (localai02)"}
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {"mode": "thresholds"},
          "thresholds": {"mode": "absolute", "steps": [{"color": "red", "value": 0}, {"color": "green", "value": 1}]},
          "mappings": [{"type": "value", "options": {"1": {"text": "UP", "color": "green"}, "0": {"text": "DOWN", "color": "red"}}}]
        }
      },
      "options": {"textMode": "auto", "colorMode": "background", "graphMode": "none", "orientation": "vertical", "reduceOptions": {"calcs": ["lastNotNull"]}}
    },

    {
      "id": 101,
      "title": "GPU Utilization % (Real-Time)",
      "type": "gauge",
      "gridPos": {"h": 4, "w": 4, "x": 4, "y": 0},
      "targets": [
        {"datasource": {"uid": "prometheus"}, "expr": "amd_smi_gpu_busy_percent{instance=\"172.31.25.75:2021\", gpu_id=\"0\"}", "legendFormat": "AMD GPU0"},
        {"datasource": {"uid": "prometheus"}, "expr": "nvidia_smi_utilization_gpu_ratio{instance=\"10.25.25.67:9835\"} * 100", "legendFormat": "NVIDIA GPU0"}
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "color": {"mode": "thresholds"},
          "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": 0}, {"color": "yellow", "value": 60}, {"color": "red", "value": 90}]}
        }
      },
      "options": {"orientation": "auto", "showThresholdLabels": true, "showThresholdMarkers": true, "reduceOptions": {"calcs": ["lastNotNull"]}}
    },

    {
      "id": 102,
      "title": "GPU Temperature (°C)",
      "type": "gauge",
      "gridPos": {"h": 4, "w": 4, "x": 8, "y": 0},
      "targets": [
        {"datasource": {"uid": "prometheus"}, "expr": "amd_smi_temperature_edge_celsius{instance=\"172.31.25.75:2021\", gpu_id=\"0\"}", "legendFormat": "AMD Edge"},
        {"datasource": {"uid": "prometheus"}, "expr": "nvidia_smi_temperature_gpu{instance=\"10.25.25.67:9835\"}", "legendFormat": "NVIDIA"}
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "celsius",
          "min": 0,
          "max": 100,
          "color": {"mode": "thresholds"},
          "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": 0}, {"color": "yellow", "value": 75}, {"color": "red", "value": 85}]}
        }
      },
      "options": {"orientation": "auto", "showThresholdLabels": true, "showThresholdMarkers": true, "reduceOptions": {"calcs": ["lastNotNull"]}}
    },

    {
      "id": 103,
      "title": "Power Draw (W)",
      "type": "gauge",
      "gridPos": {"h": 4, "w": 4, "x": 12, "y": 0},
      "targets": [
        {"datasource": {"uid": "prometheus"}, "expr": "amd_smi_power_watts{instance=\"172.31.25.75:2021\", gpu_id=\"0\"}", "legendFormat": "AMD"},
        {"datasource": {"uid": "prometheus"}, "expr": "nvidia_smi_power_draw_watts{instance=\"10.25.25.67:9835\"}", "legendFormat": "NVIDIA"}
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "watt",
          "color": {"mode": "palette-classic"}
        }
      },
      "options": {"orientation": "auto", "showThresholdLabels": false, "showThresholdMarkers": false, "reduceOptions": {"calcs": ["lastNotNull"]}}
    },

    {
      "id": 104,
      "title": "Memory Utilization %",
      "type": "gauge",
      "gridPos": {"h": 4, "w": 4, "x": 16, "y": 0},
      "targets": [
        {"datasource": {"uid": "prometheus"}, "expr": "amd_smi_memory_busy_percent{instance=\"172.31.25.75:2021\", gpu_id=\"0\"}", "legendFormat": "AMD"},
        {"datasource": {"uid": "prometheus"}, "expr": "(nvidia_smi_memory_used_bytes / nvidia_smi_memory_total_bytes) * 100", "legendFormat": "NVIDIA"}
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "color": {"mode": "thresholds"},
          "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": 0}, {"color": "yellow", "value": 70}, {"color": "red", "value": 90}]}
        }
      },
      "options": {"orientation": "auto", "showThresholdLabels": true, "showThresholdMarkers": true, "reduceOptions": {"calcs": ["lastNotNull"]}}
    },

    {
      "id": 105,
      "title": "Inference Rate (req/sec)",
      "type": "gauge",
      "gridPos": {"h": 4, "w": 4, "x": 20, "y": 0},
      "targets": [
        {"datasource": {"uid": "prometheus"}, "expr": "sum(rate(api_call_count{job=~\"localai.*\", path=\"/v1/chat/completions\"}[1m]))"}
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {"mode": "palette-classic"}
        }
      },
      "options": {"orientation": "auto", "reduceOptions": {"calcs": ["lastNotNull"]}}
    },

    {
      "id": 200,
      "title": "AMD GPU — Temperatures",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 4},
      "targets": [
        {"datasource": {"uid": "prometheus"}, "expr": "amd_smi_temperature_edge_celsius{instance=\"172.31.25.75:2021\"}", "legendFormat": "Edge {{gpu_id}}°C"},
        {"datasource": {"uid": "prometheus"}, "expr": "amd_smi_temperature_junction_celsius{instance=\"172.31.25.75:2021\"}", "legendFormat": "Junction {{gpu_id}}°C"},
        {"datasource": {"uid": "prometheus"}, "expr": "amd_smi_temperature_mem_celsius{instance=\"172.31.25.75:2021\"}", "legendFormat": "Memory {{gpu_id}}°C"}
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "celsius",
          "custom": {"lineWidth": 2, "fillOpacity": 0},
          "color": {"mode": "palette-classic"},
          "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": 0}, {"color": "yellow", "value": 75}, {"color": "red", "value": 85}]}
        }
      },
      "options": {
        "legend": {"showLegend": true, "placement": "bottom", "calcs": ["mean", "max"]},
        "tooltip": {"mode": "multi"}
      }
    },

    {
      "id": 201,
      "title": "AMD GPU — Power & Voltage",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 4},
      "targets": [
        {"datasource": {"uid": "prometheus"}, "expr": "amd_smi_power_watts{instance=\"172.31.25.75:2021\"}", "legendFormat": "Power {{gpu_id}} (W)"},
        {"datasource": {"uid": "prometheus"}, "expr": "amd_smi_max_power_watts{instance=\"172.31.25.75:2021\"}", "legendFormat": "Max Power {{gpu_id}} (W)"},
        {"datasource": {"uid": "prometheus"}, "expr": "amd_smi_voltage_mv{instance=\"172.31.25.75:2021\"} / 1000", "legendFormat": "Voltage {{gpu_id}} (V)"}
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {"lineWidth": 2, "fillOpacity": 10},
          "color": {"mode": "palette-classic"}
        }
      },
      "options": {
        "legend": {"showLegend": true, "placement": "bottom", "calcs": ["mean", "max", "last"]},
        "tooltip": {"mode": "multi"}
      }
    },

    {
      "id": 202,
      "title": "AMD GPU — Clocks & Activity",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 12},
      "targets": [
        {"datasource": {"uid": "prometheus"}, "expr": "amd_smi_avg_gfxclk_mhz{instance=\"172.31.25.75:2021\"} / 1000", "legendFormat": "GPU Clock {{gpu_id}} (GHz)"},
        {"datasource": {"uid": "prometheus"}, "expr": "amd_smi_avg_uclk_mhz{instance=\"172.31.25.75:2021\"} / 1000", "legendFormat": "Memory Clock {{gpu_id}} (GHz)"},
        {"datasource": {"uid": "prometheus"}, "expr": "amd_smi_avg_gfx_activity_percent{instance=\"172.31.25.75:2021\"}", "legendFormat": "Activity {{gpu_id}} %"}
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {"lineWidth": 2, "fillOpacity": 0},
          "color": {"mode": "palette-classic"}
        }
      },
      "options": {
        "legend": {"showLegend": true, "placement": "bottom", "calcs": ["mean", "max"]},
        "tooltip": {"mode": "multi"}
      }
    },

    {
      "id": 203,
      "title": "AMD GPU — Memory & Fan",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 12},
      "targets": [
        {"datasource": {"uid": "prometheus"}, "expr": "amd_smi_memory_busy_percent{instance=\"172.31.25.75:2021\"}", "legendFormat": "Memory Busy {{gpu_id}} %"},
        {"datasource": {"uid": "prometheus"}, "expr": "amd_smi_fan_speed_percent{instance=\"172.31.25.75:2021\"}", "legendFormat": "Fan {{gpu_id}} %"},
        {"datasource": {"uid": "prometheus"}, "expr": "amd_smi_fan_rpm{instance=\"172.31.25.75:2021\"}", "legendFormat": "Fan {{gpu_id}} RPM"}
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {"lineWidth": 2, "fillOpacity": 10},
          "color": {"mode": "palette-classic"}
        }
      },
      "options": {
        "legend": {"showLegend": true, "placement": "bottom", "calcs": ["mean", "max", "last"]},
        "tooltip": {"mode": "multi"}
      }
    },

    {
      "id": 204,
      "title": "NVIDIA GPU — Temperatures",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 20},
      "targets": [
        {"datasource": {"uid": "prometheus"}, "expr": "nvidia_smi_temperature_gpu{instance=\"10.25.25.67:9835\"}", "legendFormat": "GPU {{gpu_index}}°C"}
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "celsius",
          "custom": {"lineWidth": 3, "fillOpacity": 0},
          "color": {"mode": "palette-classic"},
          "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": 0}, {"color": "yellow", "value": 75}, {"color": "red", "value": 85}]}
        }
      },
      "options": {
        "legend": {"showLegend": true, "placement": "bottom", "calcs": ["mean", "max"]},
        "tooltip": {"mode": "multi"}
      }
    },

    {
      "id": 205,
      "title": "NVIDIA GPU — Power Draw vs Limit",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 20},
      "targets": [
        {"datasource": {"uid": "prometheus"}, "expr": "nvidia_smi_power_draw_watts{instance=\"10.25.25.67:9835\"}", "legendFormat": "Draw {{gpu_index}} (W)"},
        {"datasource": {"uid": "prometheus"}, "expr": "nvidia_smi_power_limit_watts{instance=\"10.25.25.67:9835\"}", "legendFormat": "Limit {{gpu_index}} (W)"}
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "watt",
          "custom": {"lineWidth": 2, "fillOpacity": 10},
          "color": {"mode": "palette-classic"}
        }
      },
      "options": {
        "legend": {"showLegend": true, "placement": "bottom", "calcs": ["mean", "max"]},
        "tooltip": {"mode": "multi"}
      }
    },

    {
      "id": 206,
      "title": "NVIDIA GPU — Clocks",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 28},
      "targets": [
        {"datasource": {"uid": "prometheus"}, "expr": "nvidia_smi_clock_graphics_mhz{instance=\"10.25.25.67:9835\"} / 1000", "legendFormat": "GPU Clock {{gpu_index}} (GHz)"},
        {"datasource": {"uid": "prometheus"}, "expr": "nvidia_smi_clock_memory_mhz{instance=\"10.25.25.67:9835\"} / 1000", "legendFormat": "Memory Clock {{gpu_index}} (GHz)"}
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {"lineWidth": 2, "fillOpacity": 0},
          "color": {"mode": "palette-classic"}
        }
      },
      "options": {
        "legend": {"showLegend": true, "placement": "bottom", "calcs": ["mean", "max"]},
        "tooltip": {"mode": "multi"}
      }
    },

    {
      "id": 207,
      "title": "NVIDIA GPU — Memory Usage",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 28},
      "targets": [
        {"datasource": {"uid": "prometheus"}, "expr": "nvidia_smi_memory_used_bytes{instance=\"10.25.25.67:9835\"} / 1073741824", "legendFormat": "Used {{gpu_index}} (GB)"},
        {"datasource": {"uid": "prometheus"}, "expr": "nvidia_smi_memory_free_bytes{instance=\"10.25.25.67:9835\"} / 1073741824", "legendFormat": "Free {{gpu_index}} (GB)"},
        {"datasource": {"uid": "prometheus"}, "expr": "(nvidia_smi_memory_used_bytes / nvidia_smi_memory_total_bytes) * 100", "legendFormat": "Used % {{gpu_index}}"}
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {"lineWidth": 2, "fillOpacity": 10},
          "color": {"mode": "palette-classic"}
        }
      },
      "options": {
        "legend": {"showLegend": true, "placement": "bottom", "calcs": ["mean", "max", "last"]},
        "tooltip": {"mode": "multi"}
      }
    },

    {
      "id": 208,
      "title": "NVIDIA GPU — Utilization",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 36},
      "targets": [
        {"datasource": {"uid": "prometheus"}, "expr": "nvidia_smi_utilization_gpu_ratio{instance=\"10.25.25.67:9835\"} * 100", "legendFormat": "GPU Util {{gpu_index}} %"},
        {"datasource": {"uid": "prometheus"}, "expr": "nvidia_smi_utilization_memory_ratio{instance=\"10.25.25.67:9835\"} * 100", "legendFormat": "Mem Util {{gpu_index}} %"}
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "custom": {"lineWidth": 2, "fillOpacity": 10},
          "color": {"mode": "palette-classic"}
        }
      },
      "options": {
        "legend": {"showLegend": true, "placement": "bottom", "calcs": ["mean", "max"]},
        "tooltip": {"mode": "multi"}
      }
    },

    {
      "id": 209,
      "title": "NVIDIA GPU — Fan & Throttling",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 36},
      "targets": [
        {"datasource": {"uid": "prometheus"}, "expr": "nvidia_smi_fan_speed_percent{instance=\"10.25.25.67:9835\"}", "legendFormat": "Fan {{gpu_index}} %"}
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "custom": {"lineWidth": 3, "fillOpacity": 10},
          "color": {"mode": "palette-classic"}
        }
      },
      "options": {
        "legend": {"showLegend": true, "placement": "bottom", "calcs": ["mean", "max", "last"]},
        "tooltip": {"mode": "multi"}
      }
    },

    {
      "id": 300,
      "title": "Inference Requests by Host",
      "type": "timeseries",
      "gridPos": {"h": 7, "w": 12, "x": 0, "y": 44},
      "targets": [
        {"datasource": {"uid": "prometheus"}, "expr": "sum by (host) (rate(api_call_count{job=~\"localai.*\", path=\"/v1/chat/completions\"}[1m]))", "legendFormat": "{{host}} req/sec"}
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {"lineWidth": 3, "fillOpacity": 20},
          "color": {"mode": "palette-classic"}
        }
      },
      "options": {
        "legend": {"showLegend": true, "placement": "bottom", "calcs": ["mean", "max"]},
        "tooltip": {"mode": "multi"}
      }
    },

    {
      "id": 301,
      "title": "Request Latency Percentiles",
      "type": "timeseries",
      "gridPos": {"h": 7, "w": 12, "x": 12, "y": 44},
      "targets": [
        {"datasource": {"uid": "prometheus"}, "expr": "histogram_quantile(0.50, sum by (host, le) (rate(api_call_bucket{job=~\"localai.*\", path=\"/v1/chat/completions\"}[1m])))", "legendFormat": "p50 {{host}}"},
        {"datasource": {"uid": "prometheus"}, "expr": "histogram_quantile(0.95, sum by (host, le) (rate(api_call_bucket{job=~\"localai.*\", path=\"/v1/chat/completions\"}[1m])))", "legendFormat": "p95 {{host}}"},
        {"datasource": {"uid": "prometheus"}, "expr": "histogram_quantile(0.99, sum by (host, le) (rate(api_call_bucket{job=~\"localai.*\", path=\"/v1/chat/completions\"}[1m])))", "legendFormat": "p99 {{host}}"}
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": {"lineWidth": 2, "fillOpacity": 0},
          "color": {"mode": "palette-classic"}
        }
      },
      "options": {
        "legend": {"showLegend": true, "placement": "bottom", "calcs": ["mean", "max"]},
        "tooltip": {"mode": "multi"}
      }
    },

    {
      "id": 400,
      "title": "Live Inference Traces (Click to Inspect)",
      "type": "traces",
      "gridPos": {"h": 10, "w": 24, "x": 0, "y": 51},
      "datasource": {"uid": "tempo"},
      "targets": [
        {"datasource": {"uid": "tempo"}, "queryType": "traceql", "query": "{ resource.service.name=~\"localai-.*\" } | select(span.localai.model, span.localai.backend, span.localai.tokens.prompt, span.localai.tokens.completion, span.localai.tokens_per_second, span.localai.duration_ms) | sort(startTime desc)"}
      ]
    }
  ]
}
