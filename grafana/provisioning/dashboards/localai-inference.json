{
  "title": "LocalAI — Inference Traces & Tokens",
  "uid": "localai-inference",
  "tags": ["localai", "inference", "traces", "tokens"],
  "timezone": "browser",
  "refresh": "10s",
  "schemaVersion": 38,
  "time": {"from": "now-1h", "to": "now"},
  "templating": {
    "list": [
      {
        "name": "host",
        "label": "Host",
        "type": "query",
        "datasource": {"uid": "prometheus"},
        "query": "label_values(api_call_count{job=~\"localai.*\"}, host)",
        "multi": true,
        "includeAll": true,
        "current": {"text": "All", "value": "$__all"},
        "refresh": 2
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Chat Completion Requests (req/min)",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
      "targets": [
        {
          "datasource": {"uid": "prometheus"},
          "expr": "sum by (host) (rate(api_call_count{job=~\"localai.*\", host=~\"$host\", path=\"/v1/chat/completions\"}[1m])) * 60",
          "legendFormat": "{{host}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqpm",
          "custom": {"lineWidth": 2, "fillOpacity": 10},
          "color": {"mode": "palette-classic"}
        }
      },
      "options": {
        "legend": {"showLegend": true, "placement": "bottom"},
        "tooltip": {"mode": "multi"}
      }
    },

    {
      "id": 2,
      "title": "Request Latency p50 / p95 / p99",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
      "targets": [
        {
          "datasource": {"uid": "prometheus"},
          "expr": "histogram_quantile(0.50, sum by (host, le) (rate(api_call_bucket{job=~\"localai.*\", host=~\"$host\", path=\"/v1/chat/completions\"}[1m])))",
          "legendFormat": "p50 {{host}}"
        },
        {
          "datasource": {"uid": "prometheus"},
          "expr": "histogram_quantile(0.95, sum by (host, le) (rate(api_call_bucket{job=~\"localai.*\", host=~\"$host\", path=\"/v1/chat/completions\"}[1m])))",
          "legendFormat": "p95 {{host}}"
        },
        {
          "datasource": {"uid": "prometheus"},
          "expr": "histogram_quantile(0.99, sum by (host, le) (rate(api_call_bucket{job=~\"localai.*\", host=~\"$host\", path=\"/v1/chat/completions\"}[1m])))",
          "legendFormat": "p99 {{host}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": {"lineWidth": 2, "fillOpacity": 0},
          "color": {"mode": "palette-classic"}
        }
      },
      "options": {
        "legend": {"showLegend": true, "placement": "bottom"},
        "tooltip": {"mode": "multi"}
      }
    },

    {
      "id": 3,
      "title": "Recent Inference Traces (Click to Inspect)",
      "type": "traces",
      "gridPos": {"h": 10, "w": 24, "x": 0, "y": 8},
      "datasource": {"uid": "tempo"},
      "targets": [
        {
          "datasource": {"uid": "tempo"},
          "queryType": "traceql",
          "query": "{ resource.service.name=~\"localai-.*\" } | select(span.localai.model, span.localai.backend, span.localai.tokens.prompt, span.localai.tokens.completion, span.localai.duration_ms, span.localai.tokens_per_second) | sort(startTime desc)"
        }
      ],
      "options": {
        "showSpanFilterButton": true
      }
    },

    {
      "id": 4,
      "title": "Token Counts by Host (Last 24h)",
      "type": "stat",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 18},
      "targets": [
        {
          "datasource": {"uid": "tempo"},
          "queryType": "traceql",
          "query": "{ resource.service.name=\"localai-localai01\" } | count()",
          "legendFormat": "localai01 inferences"
        },
        {
          "datasource": {"uid": "tempo"},
          "queryType": "traceql",
          "query": "{ resource.service.name=\"localai-localai02\" } | count()",
          "legendFormat": "localai02 inferences"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {"hideFrom": {"tooltip": false, "viz": false, "legend": false}},
          "color": {"mode": "thresholds"},
          "thresholds": {"mode": "absolute", "steps": [{"color": "blue", "value": null}]}
        }
      },
      "options": {
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "reduceOptions": {"values": false, "calcs": ["lastNotNull"]}
      }
    },

    {
      "id": 5,
      "title": "Tokens per Second (Live)",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 18},
      "targets": [
        {
          "datasource": {"uid": "tempo"},
          "queryType": "traceql",
          "query": "{ resource.service.name=\"localai-localai01\" } | avg(span.localai.tokens_per_second)",
          "legendFormat": "localai01"
        },
        {
          "datasource": {"uid": "tempo"},
          "queryType": "traceql",
          "query": "{ resource.service.name=\"localai-localai02\" } | avg(span.localai.tokens_per_second)",
          "legendFormat": "localai02"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {"lineWidth": 2, "fillOpacity": 0},
          "color": {"mode": "palette-classic"}
        }
      },
      "options": {
        "legend": {"showLegend": true, "placement": "bottom"},
        "tooltip": {"mode": "multi"}
      }
    },

    {
      "id": 6,
      "title": "Total Tokens (Prompt + Completion) by Host",
      "type": "piechart",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 26},
      "targets": [
        {
          "datasource": {"uid": "tempo"},
          "queryType": "traceql",
          "query": "{ resource.service.name=\"localai-localai01\" } | sum(span.localai.tokens.total)",
          "legendFormat": "localai01 tokens"
        },
        {
          "datasource": {"uid": "tempo"},
          "queryType": "traceql",
          "query": "{ resource.service.name=\"localai-localai02\" } | sum(span.localai.tokens.total)",
          "legendFormat": "localai02 tokens"
        }
      ],
      "options": {
        "legend": {"displayMode": "list", "placement": "bottom"}
      }
    },

    {
      "id": 7,
      "title": "AMD GPU localai01 — Utilization & Power",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 26},
      "targets": [
        {
          "datasource": {"uid": "prometheus"},
          "expr": "amd_smi_gpu_busy_percent{instance=\"172.31.25.75:2021\"}",
          "legendFormat": "GPU {{gpu_id}} Busy %"
        },
        {
          "datasource": {"uid": "prometheus"},
          "expr": "amd_smi_power_watts{instance=\"172.31.25.75:2021\"}",
          "legendFormat": "GPU {{gpu_id}} Power (W)"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {"lineWidth": 2, "fillOpacity": 10}
        }
      },
      "options": {
        "legend": {"showLegend": true, "placement": "bottom"},
        "tooltip": {"mode": "multi"}
      }
    },

    {
      "id": 8,
      "title": "NVIDIA GPU localai02 — Utilization & Power",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 34},
      "targets": [
        {
          "datasource": {"uid": "prometheus"},
          "expr": "nvidia_smi_utilization_gpu_ratio{instance=\"10.25.25.67:9835\"} * 100",
          "legendFormat": "GPU {{gpu_index}} Busy %"
        },
        {
          "datasource": {"uid": "prometheus"},
          "expr": "nvidia_smi_power_draw_watts{instance=\"10.25.25.67:9835\"}",
          "legendFormat": "GPU {{gpu_index}} Power (W)"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {"lineWidth": 2, "fillOpacity": 10}
        }
      },
      "options": {
        "legend": {"showLegend": true, "placement": "bottom"},
        "tooltip": {"mode": "multi"}
      }
    },

    {
      "id": 9,
      "title": "Inference Duration Heatmap (Tempo)",
      "type": "heatmap",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 34},
      "targets": [
        {
          "datasource": {"uid": "tempo"},
          "queryType": "traceql",
          "query": "{ resource.service.name=~\"localai-.*\" } | histogram_over_time(duration)"
        }
      ]
    }
  ]
}
